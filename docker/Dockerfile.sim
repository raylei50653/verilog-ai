FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    iverilog \
    verilator \
    python3 \
    python3-pip \
    build-essential \
    git \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages \
    cocotb==2.0.1 \
    pytest==8.3.2

WORKDIR /workspace

CMD ["iverilog", "-V"]
