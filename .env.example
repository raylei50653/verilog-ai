# LLM Backend (llama-server with OpenAI-compatible API)
LLM_BACKEND=llama_server
LLAMA_SERVER_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_SERVER_API_KEY=not-needed

# Model Settings
DEFAULT_MODEL=Qwen3.5-9B-UD-Q4_K_XL
MAX_RETRIES=3
TEMPERATURE=0.2
MAX_TOKENS=4096

# Docker
SIM_IMAGE=nvidia/cvdp-sim:v1.0.0

# Paths
DATA_DIR=./data
CVDP_DATASET_DIR=./data/cvdp_dataset
TRIAL_DB_PATH=./data/trials/trials.db
CONSTRAINTS_PATH=./config/constraints.json
INTERFACES_PATH=./config/interfaces.json

# Vivado (standalone analysis only, not part of pipeline)
# WSL2 + Windows Vivado: use the WSL-side path to vivado.bat or vvgl.exe
# Leave unset to auto-detect, or set to 'vivado' if Vivado is in PATH (native Linux)
VIVADO_BIN=/mnt/c/AMDDesignTools/2025.2/Vivado/bin/vivado.bat
VIVADO_PART=xc7a35tcpg236-1
# Base directory for Vivado GUI projects (WSL path to a Windows drive location)
# Defaults to Windows TEMP if unset. Each trial gets a subdirectory: <VIVADO_PROJECT_DIR>/verigen_<trial_id>
VIVADO_PROJECT_DIR=/mnt/c/Users/Ray/Documents/VeriGen/projects
