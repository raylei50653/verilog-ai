      "arvalid": "output logic",
      "arready": "input logic",
      "araddr": "output logic [ADDR_WIDTH-1:0]",
      "arprot": "output logic [2:0]",
      "rvalid": "input logic",
      "rready": "output logic",
      "rdata": "input logic [DATA_WIDTH-1:0]",
      "rresp": "input logic [1:0]"
